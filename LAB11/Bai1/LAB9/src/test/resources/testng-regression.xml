<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >
<suite name="Lab9-Regression" parallel="methods" thread-count="3">
    <parameter name="browser" value="chrome"/>
    <parameter name="env" value="dev"/>

    <listeners>
        <listener class-name="framework.utils.RetryListener"/>
    </listeners>

    <test name="Regression">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>

        <classes>
            <class name="lab9.bai2.LoginTest"/>
            <class name="lab9.bai2.CartTest"/>
            <class name="lab9.bai3.LoginDDTTest"/>
            <class name="lab9.bai4.UserLoginTest"/>
            <class name="lab9.bai4.CheckoutTest"/>
            <class name="lab9.bai6.FlakySimulationTest"/>
        </classes>
    </test>
</suite>
